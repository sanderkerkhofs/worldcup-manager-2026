generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  REFEREE
  USER
  GUEST
}

enum MatchStatus {
  PLANNED
  NOT_STARTED
  IN_PROGRESS
  FINISHED
}

model User {
  username        String    @id
  passwordHash    String
  role            UserRole  @default(USER)
  teamName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  team            Team?     @relation(fields: [teamName], references: [name], onDelete: SetNull)
  assignedMatches Match[]   @relation("AssignedReferee")
}

model Team {
  name             String   @id
  country          String
  countryShortName String
  countryFlag      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  players          Player[]
  users            User[]
  homeMatches      Match[]  @relation("HomeTeam")
  awayMatches      Match[]  @relation("AwayTeam")
  goals            Goal[]
}

model Match {
  id               Int         @id @default(autoincrement())
  roundOrderNumber Int
  roundName        String
  homeTeamName     String?
  awayTeamName     String?
  refereeUsername  String?
  homeScore        Int?
  awayScore        Int?
  matchDate        DateTime
  status           MatchStatus @default(PLANNED)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  homeTeam         Team?       @relation("HomeTeam", fields: [homeTeamName], references: [name], onDelete: Cascade)
  awayTeam         Team?       @relation("AwayTeam", fields: [awayTeamName], references: [name], onDelete: Cascade)
  referee          User?       @relation("AssignedReferee", fields: [refereeUsername], references: [username], onDelete: SetNull)
  goals            Goal[]

  @@index([roundOrderNumber])
  @@index([refereeUsername])
  @@index([homeTeamName])
  @@index([awayTeamName])
}

model Player {
  id           Int      @id @default(autoincrement())
  teamName     String
  firstName    String
  lastName     String
  shirtNumber  Int
  position     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  team         Team     @relation(fields: [teamName], references: [name], onDelete: Cascade)
  goals        Goal[]

  @@unique([teamName, shirtNumber])
  @@index([teamName])
}

model Goal {
  id           Int      @id @default(autoincrement())
  matchId      Int
  playerId     Int
  teamName     String
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team         Team     @relation(fields: [teamName], references: [name], onDelete: Cascade)

  @@index([matchId])
  @@index([playerId])
  @@index([teamName])
}
