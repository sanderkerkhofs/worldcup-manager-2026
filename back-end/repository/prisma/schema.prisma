generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ORGANIZER
  REFEREE
  VIEWER
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         UserRole  @default(VIEWER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedMatches Match[] @relation("AssignedReferee")
}

model Tournament {
  id            String           @id @default(cuid())
  name          String
  year          Int
  format        String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  rounds        Round[]
  matches       Match[]
  registrations TournamentTeam[]

  @@index([year])
}

model Team {
  id              String             @id @default(cuid())
  name            String             @unique
  country         String
  coach           String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tournamentLinks TournamentTeam[]
  homeMatches     Match[]            @relation("HomeTeam")
  awayMatches     Match[]            @relation("AwayTeam")
}

model Round {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  orderNumber  Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@unique([tournamentId, orderNumber])
  @@index([tournamentId])
}

model Match {
  id           String       @id @default(cuid())
  tournamentId String
  roundId      String
  homeTeamId   String
  awayTeamId   String
  refereeId    String?
  homeScore    Int?
  awayScore    Int?
  matchDate    DateTime
  status       MatchStatus  @default(SCHEDULED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  homeTeam     Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  referee      User?        @relation("AssignedReferee", fields: [refereeId], references: [id])

  @@index([tournamentId])
  @@index([roundId])
  @@index([refereeId])
}

model TournamentTeam {
  tournamentId String
  teamId       String
  registeredAt DateTime  @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([tournamentId, teamId])
  @@index([teamId])
}